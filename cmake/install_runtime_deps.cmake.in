if(NOT EXISTS "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/pycc")
  return()
endif()

set(_pyc_runtime_deps)
set(_pyc_unresolved_deps)
set(_pyc_execs
  "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/pycc"
)
if(EXISTS "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/pyc-opt")
  list(APPEND _pyc_execs "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_BINDIR@/pyc-opt")
endif()

file(GET_RUNTIME_DEPENDENCIES
  EXECUTABLES ${_pyc_execs}
  RESOLVED_DEPENDENCIES_VAR _pyc_runtime_deps
  UNRESOLVED_DEPENDENCIES_VAR _pyc_unresolved_deps
  POST_EXCLUDE_REGEXES
    ".*/ld-linux[^/]*\\.so.*"
    ".*/libc\\.so.*"
    ".*/libm\\.so.*"
    ".*/libpthread\\.so.*"
    ".*/libdl\\.so.*"
    ".*/librt\\.so.*"
    ".*/libgcc_s\\.so.*"
    ".*/libstdc\\+\\+\\.so.*"
    ".*/libSystem\\..*"
    ".*/System/Library/.*"
)

if(_pyc_unresolved_deps)
  message(WARNING "pyc unresolved runtime dependencies: ${_pyc_unresolved_deps}")
endif()

foreach(_pyc_dep IN LISTS _pyc_runtime_deps)
  if(EXISTS "${_pyc_dep}")
    file(INSTALL DESTINATION "${CMAKE_INSTALL_PREFIX}/@CMAKE_INSTALL_LIBDIR@" TYPE SHARED_LIBRARY FOLLOW_SYMLINK_CHAIN FILES "${_pyc_dep}")
  endif()
endforeach()
