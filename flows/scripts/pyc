#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd -- "${SCRIPT_DIR}/../.." && pwd)"

# shellcheck source=lib.sh
source "${SCRIPT_DIR}/lib.sh"

usage() {
  cat <<EOF
Usage: flows/scripts/pyc <command>

Commands:
  build        Configure+build+install pycc/pyc-opt into a staged toolchain
  smoke        Run compiler smoke (emit+pycc) and a small simulation smoke set

Env:
  LLVM_DIR, MLIR_DIR        Optional. If unset, flows/scripts/pyc infers them via llvm-config-19.
  PYC_BUILD_DIR             Optional build directory override.
  PYC_INSTALL_PREFIX        Optional install prefix override.
  PYCC                      Path to pycc (overrides auto-detect).
EOF
}

find_llvm_config() {
  if command -v llvm-config-19 >/dev/null 2>&1; then
    command -v llvm-config-19
    return 0
  fi
  if command -v llvm-config >/dev/null 2>&1; then
    local candidate
    candidate="$(command -v llvm-config)"
    if [[ "$("${candidate}" --version 2>/dev/null | cut -d. -f1)" == "19" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  fi
  return 1
}

cmd="${1:-help}"
shift || true

case "${cmd}" in
  -h|--help|help)
    usage
    ;;

  build)
    build_dir="${PYC_BUILD_DIR:-${ROOT_DIR}/.pycircuit_out/toolchain/build}"
    install_prefix="${PYC_INSTALL_PREFIX:-${ROOT_DIR}/.pycircuit_out/toolchain/install}"
    llvm_config="${LLVM_CONFIG:-}"

    while [[ $# -gt 0 ]]; do
      case "$1" in
        --build-dir)
          build_dir="${2:?missing value for --build-dir}"
          shift 2
          ;;
        --install-prefix)
          install_prefix="${2:?missing value for --install-prefix}"
          shift 2
          ;;
        --llvm-config)
          llvm_config="${2:?missing value for --llvm-config}"
          shift 2
          ;;
        *)
          pyc_die "unknown build option: $1"
          ;;
      esac
    done

    mkdir -p "${build_dir}" "${install_prefix}"

    if [[ -z "${LLVM_DIR:-}" || -z "${MLIR_DIR:-}" ]]; then
      if [[ -z "${llvm_config}" ]] && llvm_config="$(find_llvm_config)"; then
        :
      fi
      if [[ -n "${llvm_config}" ]]; then
        local_llvm_major="$("${llvm_config}" --version 2>/dev/null | cut -d. -f1)"
        if [[ "${local_llvm_major}" != "19" ]]; then
          pyc_die "LLVM 19 is required, but ${llvm_config} reports version $("${llvm_config}" --version 2>/dev/null || echo unknown)"
        fi
        pyc_log "inferring LLVM_DIR/MLIR_DIR via ${llvm_config}"
        LLVM_DIR="$("${llvm_config}" --cmakedir)"
        MLIR_DIR="$(dirname "${LLVM_DIR}")/mlir"
        export LLVM_DIR MLIR_DIR
      else
        pyc_die "set LLVM_DIR and MLIR_DIR (or provide llvm-config-19) before building"
      fi
    fi

    pyc_log "configure (${build_dir})"

    # IMPORTANT: Avoid mixing compilers when linking against the pinned LLVM/MLIR build.
    # On Windows/MSYS2, the LinxISA-pinned LLVM/MLIR is commonly built with MinGW GCC.
    # If pyCircuit is built with Clang while linking GCC-built static libs, we can hit
    # COFF/COMDAT ODR issues (multiple definitions of inline guard vars, etc.).
    # Force GCC/G++ here for MSYS2 MinGW environments.
    uname_s="$(uname -s 2>/dev/null || true)"
    cmake_args=(
      -G Ninja
      -S "${ROOT_DIR}"
      -B "${build_dir}"
      -DCMAKE_BUILD_TYPE=Release
      -DCMAKE_INSTALL_PREFIX="${install_prefix}"
      -DLLVM_DIR="${LLVM_DIR}"
      -DMLIR_DIR="${MLIR_DIR}"
    )
    if [[ "${MSYSTEM:-}" == MINGW64* || "${uname_s}" == MINGW* || "${uname_s}" == MSYS* ]]; then
      cmake_args+=(
        -DCMAKE_C_COMPILER=gcc
        -DCMAKE_CXX_COMPILER=g++
      )
    fi

    cmake "${cmake_args[@]}"

    pyc_log "build pycc + runtime (${build_dir})"
    ninja -C "${build_dir}" pycc pyc4_runtime
    ninja -C "${build_dir}" pyc-opt 2>/dev/null || true
    cmake --install "${build_dir}" --prefix "${install_prefix}"
    export PYC_TOOLCHAIN_ROOT="${install_prefix}"
    export PYCC="${install_prefix}/bin/pycc"
    pyc_log "ok: ${install_prefix}/bin/pycc"
    ;;

  smoke)
    pyc_find_pycc
    pyc_log "run example compile smoke"
    PYCC="${PYCC}" PYC_TOOLCHAIN_ROOT="${PYC_TOOLCHAIN_ROOT:-}" bash "${ROOT_DIR}/flows/scripts/run_examples.sh"
    pyc_log "run simulation smoke"
    PYCC="${PYCC}" PYC_TOOLCHAIN_ROOT="${PYC_TOOLCHAIN_ROOT:-}" bash "${ROOT_DIR}/flows/scripts/run_sims.sh"
    pyc_log "ok: smoke passed"
    ;;

  *)
    pyc_die "unknown command: ${cmd} (run: flows/scripts/pyc help)"
    ;;
esac
